# ============================================================
# OBSCURA — konfigurasi. Salin file ini menjadi ".env"
# ============================================================

# --- RPC (Lapisan 1) ---
# Mantle wajib. Default publik gratis di bawah cukup untuk memulai.
# Untuk lebih stabil: daftar gratis di dRPC/QuickNode, ganti URL ini.
MANTLE_RPC=https://rpc.mantle.xyz

# Chain lain (opsional — untuk multi-chain nanti). Default publik:
ETHEREUM_RPC=https://eth.llamarpc.com
BASE_RPC=https://mainnet.base.org
BSC_RPC=https://bsc-dataseed.binance.org
POLYGON_RPC=https://polygon-rpc.com
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC=https://mainnet.optimism.io

# --- AI (Lapisan narasi, opsional) ---
# Tanpa ini, server tetap jalan dengan narasi template.
# Dapatkan dari console.anthropic.com
# ANTHROPIC_API_KEY=

# --- Deploy contract (Lapisan 3, Langkah 5) ---
# WAJIB pakai wallet TEST khusus. JANGAN wallet utama. JANGAN commit ke GitHub.
# PRIVATE_KEY=
# LEDGER_ADDRESS=

# Port server
PORT=3000
